@host = http://localhost:5000

### Sign up
POST {{host}}/Auth/sign-up
Content-Type: application/json

{
  "email": "test@example.com",
  "userName": "tester",
  "password": "secret123",
  "fullName": "Test User"
}

### Sing in
POST {{host}}/Auth/sign-in
Content-Type: application/json

{
  "email": "test@example.com",
  "password": "secret123"
}

### Sign up with real email confirmation
POST {{host}}/Auth/sign-up
Content-Type: application/json

{
  "email": "gargas.w@gmail.com",
  "userName": "Wojtek",
  "password": "secret123",
  "fullName": "Wojciech Gargas"
}
