{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*",
  "app" : {
    "name": "Streakly API"
  },
  "postgres": {
    "ConnectionString": "Host=localhost;Port=5436;Database=Streakly2.0;Username=postgres;Password=postgres"
  },
  "auth": {
    "issuer": "streakly",
    "audience": "streakly-api",
    "signingKey": "streakly-local-dev-signing-key-placeholder-please-replace-in-production-2026",
    "expiry": "01:00:00"
  },
  "emailConfirmation": {
    "issuer": "streakly-email",
    "audience": "streakly-email-confirmation",
    "signingKey": "streakly-local-dev-email-confirmation-signing-key-placeholder-replace-in-production-2026",
    "frontendConfirmUrl": "https://your-frontend-domain/confirm-email",
    "expiry": "1.00:00:00"
  },
  "smtp": {
    "host": "email-smtp.eu-central-1.amazonaws.com",
    "port": 587,
    "username": "replace-with-ses-smtp-username",
    "password": "replace-with-ses-smtp-password",
    "fromEmail": "streakly@wojciechgargas.com",
    "fromName": "Streakly App",
    "useSsl": true
  },
  "cors": {
    "allowedOrigins": [
      "https://your-frontend-domain"
    ]
  },
  "hangfire": {
    "schema": "hangfire",
    "cleanupCron": "0 12 * * *",
    "dashboardEnabled": true
  }
}
